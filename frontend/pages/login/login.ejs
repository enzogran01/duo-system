<%- include('../includes/head') %>

    <main class="w-full h-full flex items-center justify-center">
        <div class="w-[75%] md:w-[50%] lg:w-[25%] p-6 rounded-lg text-black bg-white" data-aos="fade-up" data-aos-offset="10" data-aos-delay="100" data-aos-duration="1000">

            <p class="w-full text-center text-lg"> Bem-vinda de volta! </p>
            <p class="w-full text-center text-base text-neutral-800 "> Para continuar, por favor faça login. </p>

            <% if (errors && errors.length > 0) { %>
                <div class="w-full mb-4 mt-2 p-3 rounded-md bg-red-100 text-red-600 text-sm text-center">
                    <p> <%= errors %> </p>
                </div>
            <% } %>

            <form id="formLogin" action="/" method="POST" class="w-full">
                <div class="mt-8 input-div">
                    <input placeholder="Seu email" autofocus type="email" name="email" id="email" required class="w-full border-b rounded-t px-3 py-2 outline-none focus:bg-neutral">
                </div>
                <div class="mt-2 relative input-div">
                    <input placeholder="Sua senha" type="password" name="password" id="password" maxlength="44" minlength="8" required class="w-full border-b rounded-t px-3 py-2 outline-none focus:bg-neutral">
                    <button id="revealPasswordBtn" type="button" class="cursor-pointer absolute right-2 top-[20%]"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15.58 12c0 1.98-1.6 3.58-3.58 3.58S8.42 13.98 8.42 12s1.6-3.58 3.58-3.58 3.58 1.6 3.58 3.58Z" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 20.27c3.53 0 6.82-2.08 9.11-5.68.9-1.41.9-3.78 0-5.19-2.29-3.6-5.58-5.68-9.11-5.68-3.53 0-6.82 2.08-9.11 5.68-.9 1.41-.9 3.78 0 5.19 2.29 3.6 5.58 5.68 9.11 5.68Z" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg></button>
                </div>

                <div class="w-full items-center justify-center mt-6">
                    <button type="submit" class="text-center w-full p-4 rounded-md transition-all duration-100 cursor-pointer text-white bg-action hover:-translate-y-1">Login</button>
                </div>
            </form>
        </div>
    </main>

<%- include('../includes/footer') %>