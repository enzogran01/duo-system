<%- include('../includes/head') %>

    <main class="w-full h-full flex flex-col md:flex-row pt-15 md:pt-16">
        <nav class="w-full h-16 flex justify-evenly md:w-[20%] md:h-screen md:flex-col md:justify-start bg-white" data-aos="fade-right" data-aos-offset="10" data-aos-delay="200" data-aos-duration="1000">
            <button id="fichasSectionBtn" class="flex py-2 sm:py-0 items-center outline-none justify-start w-full md:min-h-15 cursor-pointer hover:bg-black/10 transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="ml-6 mr-4" width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M20 8.25V18c0 3-1.79 4-4 4H8c-2.21 0-4-1-4-4V8.25c0-3.25 1.79-4 4-4 0 .62.25 1.18.66 1.59.41.41.97.66 1.59.66h3.5C14.99 6.5 16 5.49 16 4.25c2.21 0 4 .75 4 4Z" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16 4.25c0 1.24-1.01 2.25-2.25 2.25h-3.5c-.62 0-1.18-.25-1.59-.66C8.25 5.43 8 4.87 8 4.25 8 3.01 9.01 2 10.25 2h3.5c.62 0 1.18.25 1.59.66.41.41.66.97.66 1.59ZM8 13h4M8 17h8" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                <p class="text-action cursor-pointer text-left">Fichas</p>
            </button>
            <button id="atendimentosSectionBtn" class="flex py-2 sm:py-0 items-center outline-none justify-start w-full md:min-h-15 cursor-pointer hover:bg-black/10 transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="ml-6 mr-4" width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M18.63 7.15c.04.61-.01 1.3-.13 2.07l-.73 4.69c-.62 3.91-2.43 5.23-6.34 4.62l-4.69-.74c-1.35-.21-2.39-.57-3.15-1.11-1.45-1.01-1.87-2.67-1.47-5.23l.74-4.69c.62-3.91 2.43-5.23 6.34-4.62l4.69.74c3.14.49 4.61 1.77 4.74 4.27Z" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M20.5 13.47 19 17.98c-1.25 3.76-3.25 4.76-7.01 3.51l-4.51-1.5c-2.27-.75-3.53-1.79-3.89-3.31.76.54 1.8.9 3.15 1.11l4.69.74c3.91.61 5.72-.71 6.34-4.62l.73-4.69c.12-.77.17-1.46.13-2.07 2.39 1.27 2.91 3.19 1.87 6.32ZM8.24 8.98a1.74 1.74 0 1 0 0-3.48 1.74 1.74 0 0 0 0 3.48Z" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                <p class="text-action cursor-pointer text-left">Atendimentos</p>
            </button>
        </nav>

        <!-- Fichas - visível por padrão -->
        <section id="fichasSection" class="w-full p-6 md:p-16" data-aos="fade-right" data-aos-offset="10" data-aos-delay="10000" data-aos-duration="1000">
            <div class="w-full mb-6 flex flex-col sm:flex-row items-center justify-between">
                <h1 class="text-xl mb-2 sm:mb-0">Fichas de pacientes</h1>
                <input 
                    type="text" 
                    id="searchPaciente" 
                    placeholder="Buscar por nome, telefone ou profissão" 
                    class="w-full lg:w-[60%] mb-2 sm:mb-0 bg-white px-4 py-2 rounded-lg transition-all focus:outline-none focus:ring-1 focus:ring-action"
                />
                <a href="/ficha/new" class="text-white w-full sm:w-auto bg-action rounded-sm py-2 px-3 sm:py-4 sm:px-6 border cursor-pointer transition-all hover:-translate-y-1">Adicionar ficha</a>
            </div>

            <section class="grid grid-cols-1 gap-1 sm:grid-cols-4 sm:gap-4">
                <% if (fichas && fichas.length > 0) { %>
                <% fichas.forEach(ficha => { %>
                    <div class="flex flex-col w-full p-4 rounded-xl bg-white" data-nome="<%= ficha.nome %>" data-telefone="<%= ficha.telefone %>" data-profissao="<%= ficha.profissao %>" data-id="<%= ficha._id %>">
                        <div class="flex flex-col w-full">
                            <p class="font-bold text-lg mb-2 truncate"><%= ficha.nome %></p>
                            <p class="text-sm text-gray-500"><%= ficha.telefone %></p>
                            <p class="text-sm text-gray-500 mb-1"><%= ficha.profissao %></p>
                            <a href="/ficha/<%= ficha._id %>" class="detalhes-ficha w-full rounded bg-action text-white py-2 px-4 mt-2 transition-all cursor-pointer hover:-translate-y-0.5">Ver detalhes</a>
                        </div>
                    </div>
                <% }) %>
                <% } else { %>
                    <p>Nenhuma ficha cadastrada por enquanto.</p>
                <% } %>
            </section>
        </section>

        <!-- Atendimentos - escondida por padrão -->
        <section id="atendimentosSection" class="hidden w-full p-6 md:p-16" data-aos-offset="10" data-aos-delay="10000" data-aos-duration="1000">
            <h1 class="text-xl font-bold">Atendimentos</h1>
        </section>
    </main>

<%- include('../includes/footer') %>