<%- include('../includes/head') %>
    <dialog id="modalAtendimento" class="rounded-lg p-6 w-full max-w-md m-auto backdrop:bg-black/50">
        <h2 class="text-lg font-medium mb-4" id="modal-paciente">Detalhes do Atendimento</h2>
        <div class="flex flex-col gap-2 text-sm">
            <p><span class="font-medium tel">Data:</span> <span id="modal-data"></span></p>
            <p><span class="font-medium tel">Telefone:</span> <span id="modal-telefone"></span></p>
            <p><span class="font-medium">Serviço:</span> <span id="modal-servico"></span></p>
            <p><span class="font-medium">Profissional:</span> <span id="modal-profissional"></span></p>
            <p><span class="font-medium">Observação:</span> <span id="modal-observacao" class="italic text-black/50"></span></p>
        </div>
        <button id="modalCloseBtn" class="mt-6 w-full p-3 rounded-md bg-action text-white cursor-pointer">Fechar</button>
    </dialog>

    <main class="w-full flex flex-col pt-32 px-12 md:px-32">

        <% if (errors && errors.length > 0) { %>
            <div class="w-full mb-4 mt-2 p-3 rounded-md bg-red-100 text-red-600 text-sm text-center">
                <p> <%= errors %> </p>
            </div>
        <% } %>

        <div class="flex flex-col sm:flex-row w-full gap-3" data-aos="fade-up" data-aos-offset="10" data-aos-delay="100" data-aos-duration="1000">
            <input type="search" placeholder="Pesquisar por item" class="rounded-sm flex-1 text-center sm:text-left bg-white outline-none p-4">
            <button class="flex items-center justify-center gap-2 whitespace-nowrap rounded-sm shrink-0 w-full sm:w-48 bg-action text-white outline-none p-4 cursor-pointer hover:shadow-[0_2px_4px_0_rgba(0,0,0,0.2)] hover:-translate-y-0.5 transition-all duration-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M6 12h12M12 18V6" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                Novo atendimento
            </button>
        </div>

        <div class="mt-10 w-full overflow-x-auto" data-aos="fade-right" data-aos-offset="10" data-aos-delay="500" data-aos-duration="1000">
            <% if (atendimentos.length === 0) { %>
                <p class="text-black/50 italic">Sem atendimentos por enquanto...</p>
            <% } else { %>
                <table class="w-full border-collapse min-w-150">
                <thead>
                    <tr class="bg-action text-white text-left">
                        <th class="p-4 font-medium">Nome</th>
                        <th class="p-4 font-medium">Telefone</th>
                        <th class="p-4 font-medium">Serviço</th>
                        <th class="p-4 font-medium">Profissional</th>
                        <th class="p-4 font-medium">Data</th>
                        <th class="p-4 font-medium">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% atendimentos.forEach(atendimento => { %>
                        <tr class="border-b border-secondary bg-white hover:bg-tertiary transition-colors duration-150">
                            <td class="p-4 text-sm"><%= atendimento.paciente %></td>
                            <td class="p-4 text-sm tel"><%= atendimento.telefone || '---' %></td>
                            <td class="p-4 text-sm"><%= atendimento.servico %></td>
                            <td class="p-4 text-sm"><%= atendimento.profissional %></td>
                            <td class="p-4 text-sm"><%= new Date(atendimento.dataAtendimento).toLocaleDateString('pt-BR') %></td>
                            <td class="p-4 text-sm flex justify-evenly">
                            <!-- visualizar --> <svg class="view-btn cursor-pointer transition-all hover:scale-110 outline-none" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M15.58 12c0 1.98-1.6 3.58-3.58 3.58S8.42 13.98 8.42 12s1.6-3.58 3.58-3.58 3.58 1.6 3.58 3.58Z" stroke="#130809" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M12 20.27c3.53 0 6.82-2.08 9.11-5.68.9-1.41.9-3.78 0-5.19-2.29-3.6-5.58-5.68-9.11-5.68-3.53 0-6.82 2.08-9.11 5.68-.9 1.41-.9 3.78 0 5.19 2.29 3.6 5.58 5.68 9.11 5.68Z" stroke="#130809" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                            <!-- editar --> <svg class="edit-btn cursor-pointer transition-all hover:scale-110 outline-none" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M11 2H9C4 2 2 4 2 9v6c0 5 2 7 7 7h6c5 0 7-2 7-7v-2" stroke="#120309" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.04 3.02 8.16 10.9c-.3.3-.6.89-.66 1.32l-.43 3.01c-.16 1.09.61 1.85 1.7 1.7l3.01-.43c.42-.06 1.01-.36 1.32-.66l7.88-7.88c1.36-1.36 2-2.94 0-4.94-2-2-3.58-1.36-4.94 0Z" stroke="#120309" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"></path><path d="M14.91 4.15a7.144 7.144 0 0 0 4.94 4.94" stroke="#120309" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                            <!-- excluir --> <a href="/atendimento/delete/<%=atendimento._id%>"> <svg class="cursor-pointer transition-all hover:scale-110 delete-btn" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M21 5.98c-3.33-.33-6.68-.5-10.02-.5-1.98 0-3.96.1-5.94.3L3 5.98M8.5 4.97l.22-1.31C8.88 2.71 9 2 10.69 2h2.62c1.69 0 1.82.75 1.97 1.67l.22 1.3M18.85 9.14l-.65 10.07C18.09 20.78 18 22 15.21 22H8.79C6 22 5.91 20.78 5.8 19.21L5.15 9.14M10.33 16.5h3.33M9.5 12.5h5" stroke="#120309" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg> </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </main>

    <form action="/dashbaord" method="POST"></form>

<%- include('../includes/footer') %>