<%- include('../includes/head') %>

    <main class="w-full h-full flex flex-col md:flex-row pt-15 md:pt-16">
        <section class="w-full p-6 md:p-16" data-aos="fade-right" data-aos-offset="10" data-aos-delay="10000" data-aos-duration="1000">
            <div class="w-full flex flex-col md:flex-row items-center justify-between md:mb-6">
                <div class="flex flex-col w-full md:w-auto md:flex-row items-start md:items-center gap-2 md:gap-4">
                    <a href="/" class="text-action bg-white rounded-xl p-2 w-fit transition-all hover:-translate-y-0.5">Voltar</a>
                    <h1 class="text-xl text-center font-bold mb-4 md:mb-2 lg:mb-0">Criar nova ficha</h1>
                </div>
                
                <div class="flex p-2.5 bg-white rounded gap-8 mb-4 md:mb-0">
                    <!-- atendimentos -->
                    <button id="resetInputsBtn" data-tippy-content="Limpar campos" class="cursor-pointer transition-all hover:-translate-y-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rotate-ccw-icon lucide-rotate-ccw"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                    </button>
                </div>
            </div>

            <div class="w-full bg-white rounded p-6">
                <h2 class="font-bold text-xl border-b pb-1 mb-4">Dados pessoais</h2>

                <form method="POST" action="/ficha/new" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="form-item flex flex-col">
                        <label for="nome">Nome completo*</label>
                        <input type="text" id="nome" name="nome" value="" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" required>
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="telefone">Telefone*</label>
                        <input type="tel" id="telefone" name="telefone" maxlength="11" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" required>
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="profissao">Profissão</label>
                        <input type="text" id="profissao" name="profissao" value="" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" >
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="data_nascimento">Data de nascimento</label>
                        <input type="date" id="data_nascimento" name="data_nascimento" value="" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" >
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="peso">Peso (em kg)</label>
                        <input type="number" id="peso" name="peso" value="" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" >
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="altura">Altura (em metros)</label>
                        <input type="number" id="altura" name="altura" value="" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" >
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="medida">Medida (em cm)</label>
                        <input type="number" id="medida" name="medida" value="" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral" >
                    </div>

                    <div class="form-item flex flex-col">
                        <label for="pele">Cor de pele</label>
                        <select name="pele" id="pele" class="create-input p-2 rounded-t border-b transition-all focus:outline-none focus:bg-neutral">
                            <option value="" disabled selected>Selecione</option>
                            <option value="branca">Branca</option>
                            <option value="preta">Preta</option>
                            <option value="parda">Parda</option>
                            <option value="amarela">Amarela</option>
                            <option value="indigena">Vermelha</option>
                        </select>
                    </div>

                    <button id="submitEditButton" class="bg-action text-white rounded p-4 cursor-pointer transition-all w-full md:w-fit hover:-translate-y-0.5 disabled:bg-action/60 disabled:cursor-auto disabled:hover:translate-y-0" type="submit" disabled>Confirmar</button>
                </form>
            </div>
        </section>
    </main>

<%- include('../includes/footer') %>